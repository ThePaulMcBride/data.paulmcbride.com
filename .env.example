# Web server
PORT=8000
CONTENT_DIR=content
PUBLIC_DIR=public

# Mastodon sync
MASTODON_BASE_URL=https://example.social
MASTODON_ACCESS_TOKEN=
MASTODON_ACCOUNT_ID=

# Optional Mastodon media mirroring to Backblaze B2 S3-compatible storage
B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET=media.paulmcbride.com
B2_REGION=us-west-004
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_PUBLIC_BASE_URL=https://media.paulmcbride.com
B2_KEY_PREFIX=mastodon

# Railway Mastodon sync cron
GITHUB_ACCESS_TOKEN=
